# 统一以 LF 入库，避免 Windows / WSL 之间反复出现“整文件被改”的假改动
* text=auto eol=lf

# 二进制文件按二进制处理，绝不做行尾转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.tar.gz binary
*.tar.xz binary
*.tar.bz2 binary
*.7z binary
*.iso binary
*.img binary
*.exe binary
*.dll binary
*.so binary
*.a binary
*.o binary
*.obj binary
*.bin binary
*.elf binary
*.rknn binary
*.onnx binary
*.pth binary
*.pt binary
*.weights binary
*.whl binary
*.pb binary

# Windows 专属脚本保持 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Linux 脚本强制 LF（即使在 Windows 下编辑也保持 LF，避免端侧执行失败）
*.sh text eol=lf
